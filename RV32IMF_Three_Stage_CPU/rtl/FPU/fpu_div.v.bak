module fpu_div (
    input  wire [31:0] fs1_data,  // 被除数 Dividend
    input  wire [31:0] fs2_data,  // 除数 Divisor
    input  wire [2:0]  rm,        // 舍入模式 (默认 RNE: 3'b000)
    output reg  [31:0] fd_data,   // 结果输出
    output wire [4:0]  fflags     // 异常标志位 (简化)
);

    assign fflags = 5'b00000;

    // 1. 浮点数解包 & 异常值检测
    wire        sign_a = fs1_data[31];
    wire [7:0]  exp_a  = fs1_data[30:23];
    wire [22:0] frac_a = fs1_data[22:0];
    wire a_is_zero = (exp_a == 8'd0);
    wire a_is_inf  = (exp_a == 8'hFF) && (frac_a == 23'd0);
    wire a_is_nan  = (exp_a == 8'hFF) && (frac_a != 23'd0);

    wire        sign_b = fs2_data[31];
    wire [7:0]  exp_b  = fs2_data[30:23];
    wire [22:0] frac_b = fs2_data[22:0];
    wire b_is_zero = (exp_b == 8'd0);
    wire b_is_inf  = (exp_b == 8'hFF) && (frac_b == 23'd0);
    wire b_is_nan  = (exp_b == 8'hFF) && (frac_b != 23'd0);

    // 2. 符号判定与指数相减
    wire final_sign = sign_a ^ sign_b;
    
    // 采用 11 位有符号数防止计算越界
    wire signed [10:0] true_exp_a = {3'b0, exp_a} - 11'd127;
    wire signed [10:0] true_exp_b = {3'b0, exp_b} - 11'd127;
    wire signed [10:0] true_exp_res = true_exp_a - true_exp_b;

    // 3. 尾数扩位除法 (Fraction Division)
    wire [23:0] mant_a = {1'b1, frac_a};
    wire [23:0] mant_b = {1'b1, frac_b};
    
    // 将被除数左移 26 位，以获取 23位尾数 + G + R + S位预留
    wire [49:0] dividend = {mant_a, 26'd0};
    wire [23:0] divisor  = mant_b;
    
    // 核心除法运算（EDA工具将综合为除法器逻辑）
    wire [26:0] quotient = b_is_zero ? 27'd0 : (dividend / divisor);
    wire [23:0] remainder= b_is_zero ? 24'd0 : (dividend % divisor);

    // 4. 规格化与 GRS 提取 (Normalization)
    // 商的范围在 [0.5, 2)。
    // 如果 quotient[26] == 1，说明结果 >= 1.0 (例如 1.5)，格式为 1.xxx
    // 如果 quotient[26] == 0，说明结果 < 1.0 (例如 0.75)，格式为 0.1xxx
    wire norm_shift = ~quotient[26]; 
    
    // 如果最高位是 0，整个尾数需要左移 1 位，吃掉高位的 0
    wire [22:0] norm_frac = norm_shift ? quotient[24:2] : quotient[25:3];
    
    // 提取舍入位
    wire G = norm_shift ? quotient[1] : quotient[2];
    wire R = norm_shift ? quotient[0] : quotient[1];
    // 经典逻辑：Sticky 位不仅看商的末尾，只要余数不为0，说明无限循环，必为1！
    wire S = norm_shift ? (remainder != 24'd0) : (quotient[0] | (remainder != 24'd0));

    // 5. 舍入逻辑 (Rounding RNE)
    reg round_up;
    always @(*) begin
        case(rm)
            3'b000: round_up = G & (R | S | norm_frac[0]); // RNE
            3'b001: round_up = 1'b0;                       // RTZ
            3'b010: round_up = final_sign & (G | R | S);   // RDN
            3'b011: round_up = ~final_sign & (G | R | S);  // RUP
            3'b100: round_up = G;                          // RMM
            default: round_up = G & (R | S | norm_frac[0]);
        endcase
    end

    wire [23:0] rounded_frac_ext = {1'b0, norm_frac} + round_up;
    wire round_ovf = rounded_frac_ext[23];
    wire [22:0] final_frac = round_ovf ? 23'd0 : rounded_frac_ext[22:0];

    // 6. 最终指数与异常拦截
    // 如果发生左移规格化，指数-1；如果舍入导致溢出，指数+1
    wire signed [10:0] final_true_exp = true_exp_res - norm_shift + round_ovf;
    wire signed [10:0] final_exp_biased = final_true_exp + 11'd127;

    wire invalid_op = (a_is_zero & b_is_zero) | (a_is_inf & b_is_inf); // 0/0 或 Inf/Inf
    wire div_by_zero= ~a_is_zero & b_is_zero; // X/0
    wire any_nan    = a_is_nan | b_is_nan | invalid_op;

    always @(*) begin
        if (any_nan) begin
            fd_data = 32'h7FC00000; // NaN
        end else if (div_by_zero || a_is_inf || b_is_zero) begin
            // 除以0，或者被除数是Inf，结果是Inf
            fd_data = {final_sign, 8'hFF, 23'd0};
        end else if (a_is_zero || b_is_inf || final_exp_biased <= 0) begin
            // 0除以任何数，任何数除以Inf，或者下溢出 (FTZ)，结果是0
            fd_data = {final_sign, 31'd0};
        end else if (final_exp_biased >= 255) begin
            // 上溢出
            fd_data = {final_sign, 8'hFF, 23'd0};
        end else begin
            // 正常数值
            fd_data = {final_sign, final_exp_biased[7:0], final_frac};
        end
    end

endmodule
