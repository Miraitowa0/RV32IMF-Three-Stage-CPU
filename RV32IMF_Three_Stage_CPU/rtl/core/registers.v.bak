`include "define.v"

//`define INITIAL
module registers(
	clk,
	rst_n,
	Rs1,
	Rs2,
	Rd,
	W_en,
	Wr_Data,
	Rs1_Data,
	Rs2_Data
);
	input clk;
	input rst_n;
	input [4:0]Rs1;
	input [4:0]Rs2;
	input [4:0]Rd;
	input W_en;
	input [31:0]Wr_Data;
	output [31:0]Rs1_Data;
	output [31:0]Rs2_Data;

	reg [31:0]regs[31:0];
	
/////////////仿真测试所需代码//////////////	
	initial begin 
    // 读取初始化文件，赋值给regs（对应索引0~31）
    // 格式：$readmemh("文件路径", 数组名, 起始索引, 结束索引)
    $readmemh("E:/RISCV_Prj/RV321M_ThreeStage/regs_init.txt", regs, 0, 31);
    
    // 可选：调试打印，验证读取结果
    $display("regs[0] = %h", regs[0]); // 预期输出：00000000
    $display("regs[1] = %h", regs[1]); // 预期输出：AABBCCDD
	 $display("regs[2] = %h", regs[2]); // 预期输出：00112233
	 $display("regs[3] = %h", regs[3]); // 预期输出：11335577
	 $display("regs[4] = %h", regs[4]); // 预期输出：FFFF0000
end
	
`ifdef INITIAL
	always@(negedge clk )//时钟下降沿写入 解决数据冒险问题
		begin
			if(W_en & (Rd!=0))
			regs[Rd]<=Wr_Data;	
		end
`else		
	always@(negedge clk ) //仿真时初始化寄存器，全部复位，防止逻辑错误出现未知态
		begin
			if(!rst_n) begin
					regs[0]<=`zero_word;
					regs[1]<=`zero_word;
					regs[2]<=`zero_word;
					regs[3]<=`zero_word;
					regs[4]<=`zero_word;
					regs[5]<=`zero_word;
					regs[6]<=`zero_word;
					regs[7]<=`zero_word;
					regs[8]<=`zero_word;
					regs[9]<=`zero_word;
					regs[10]<=`zero_word;
					regs[11]<=`zero_word;
					regs[12]<=`zero_word;
					regs[13]<=`zero_word;
					regs[14]<=`zero_word;
					regs[15]<=`zero_word;
					regs[16]<=`zero_word;
					regs[17]<=`zero_word;
					regs[18]<=`zero_word;
					regs[19]<=`zero_word;
					regs[20]<=`zero_word;
					regs[21]<=`zero_word;
					regs[22]<=`zero_word;
					regs[23]<=`zero_word;
					regs[24]<=`zero_word;
					regs[25]<=`zero_word;
					regs[26]<=`zero_word;
					regs[27]<=`zero_word;
					regs[28]<=`zero_word;
					regs[29]<=`zero_word;
					regs[30]<=`zero_word;
					regs[31]<=`zero_word;
				end
			else if(W_en & (Rd!=0)) begin
					regs[Rd]<=Wr_Data;
			end	
		end
`endif	

	assign Rs1_Data = (Rs1 == 5'd0) ? 32'd0 : regs[Rs1];
	assign Rs2_Data = (Rs2 == 5'd0) ? 32'd0 : regs[Rs2];
	

endmodule

